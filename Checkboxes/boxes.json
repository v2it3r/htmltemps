[
  {
    "id": "cb-minimal-blue",
    "name": "Standard Checkbox",
    "description": "A refined, modern checkbox with subtle elevation and a crisp enterprise-blue confirmation state.",
    "html": "<label class=\"cb-normal-wrap\"><input type=\"checkbox\" class=\"cb-normal-input\" /><div class=\"cb-normal-box\"><svg class=\"cb-normal-check\" viewBox=\"0 0 24 24\"><path d=\"M20 6L9 17l-5-5\" /></svg></div></label>",
    "css": ".cb-normal-wrap{display:inline-flex;align-items:center;cursor:pointer;user-select:none}.cb-normal-input{display:none}.cb-normal-box{width:18px;height:18px;border:1.5px solid #c7ced9;border-radius:4px;background:linear-gradient(#ffffff,#f7f9fc);display:flex;align-items:center;justify-content:center;transition:border-color .18s ease,background .18s ease,box-shadow .18s ease}.cb-normal-wrap:hover .cb-normal-box{border-color:#3b6fd8}.cb-normal-input:checked + .cb-normal-box{background:linear-gradient(#2f6fe4,#1f5bd1);border-color:#2f6fe4;box-shadow:0 0 0 2px rgba(47,111,228,0.15)}.cb-normal-check{width:12px;height:12px;fill:none;stroke:#fff;stroke-width:3.2;stroke-linecap:round;stroke-linejoin:round;opacity:0;transition:opacity .15s ease}.cb-normal-input:checked + .cb-normal-box .cb-normal-check{opacity:1}",
    "js": ""
  },

  {
