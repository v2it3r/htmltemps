[
  {
    "id": "cb-classic-pill",
    "name": "Classic Checkbox Blue",
    "description": "The definitive digital checkbox featuring a refined modern frame with a clean enterprise-blue confirmation fill.",
    "html": "<label class=\"cb-pill-wrap\"><input type=\"checkbox\" class=\"cb-pill-input\" /><div class=\"cb-pill-box\"><svg class=\"cb-pill-check\" viewBox=\"0 0 24 24\"><path d=\"M20 6L9 17l-5-5\" /></svg></div></label>",
    "css": ".cb-pill-wrap{display:inline-flex;align-items:center;cursor:pointer;user-select:none}.cb-pill-input{display:none}.cb-pill-box{width:18px;height:18px;border:1.5px solid #c7ced9;border-radius:4px;background:linear-gradient(#ffffff,#f7f9fc);display:flex;align-items:center;justify-content:center;transition:border-color .18s ease,background .18s ease,box-shadow .18s ease}.cb-pill-wrap:hover .cb-pill-box{border-color:#3b6fd8}.cb-pill-input:checked + .cb-pill-box{background:linear-gradient(#2f6fe4,#1f5bd1);border-color:#2f6fe4;box-shadow:0 0 0 2px rgba(47,111,228,0.15)}.cb-pill-check{width:12px;height:12px;fill:none;stroke:#fff;stroke-width:3.2;stroke-linecap:round;stroke-linejoin:round;opacity:0;transition:opacity .15s ease}.cb-pill-input:checked + .cb-pill-box .cb-pill-check{opacity:1}",
    "js": ""
  },
