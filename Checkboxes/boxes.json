  {
    "id": "cb-subtle-dot",
    "name": "Classic Radio-Box Dot",
    "description": "A hybrid square checkbox with a clean, centered confirmation dot.",
    "html": "<label class=\"cb-dot-wrap\"><input type=\"checkbox\" class=\"cb-dot-input\" /><div class=\"cb-dot-box\"><span></span></div></label>",
    "css": ".cb-dot-wrap{display:inline-flex;cursor:pointer}.cb-dot-input{display:none}.cb-dot-box{width:18px;height:18px;border:1.5px solid #cbd5e1;background:#ffffff;border-radius:4px;display:flex;align-items:center;justify-content:center;transition:border-color .18s ease}.cb-dot-box span{width:8px;height:8px;background:#2f6fe4;border-radius:2px;opacity:0;transition:opacity .15s ease}.cb-dot-input:checked + .cb-dot-box{border-color:#2f6fe4}.cb-dot-input:checked + .cb-dot-box span{opacity:1}",
