  {
    "id": "cb-triple-group",
    "name": "Multi Matrix Array (3x)",
    "description": "A structured triple-checkbox row with unified spacing and consistent enterprise styling.",
    "html": "<div class=\"cb-grp-row\"><label class=\"cb-grp-item\"><input type=\"checkbox\" checked /><div></div></label><label class=\"cb-grp-item\"><input type=\"checkbox\" /><div></div></label><label class=\"cb-grp-item\"><input type=\"checkbox\" /><div></div></label></div>",
    "css": ".cb-grp-row{display:flex;gap:6px;background:#ffffff;padding:4px;border-radius:6px;border:1px solid #e2e8f0}.cb-grp-item{cursor:pointer;display:flex}.cb-grp-item input{display:none}.cb-grp-item div{width:18px;height:18px;border:1.5px solid #cbd5e1;background:#ffffff;border-radius:4px;transition:border-color .18s ease,background .18s ease}.cb-grp-item input:checked + div{background:#2f6fe4;border-color:#2f6fe4}",
    "js": ""
  },

  {
    "id": "cb-dual-horizontal",
    "name": "Split Multi-Node Block",
    "description": "A dual segmented control with clean typography and subtle active-state highlighting.",
    "html": "<div class=\"cb-split-box\"><label class=\"cb-split-side\"><input type=\"checkbox\" /><span>A</span></label><label class=\"cb-split-side\"><input type=\"checkbox\" /><span>B</span></label></div>",
    "css": ".cb-split-box{display:flex;border:1.5px solid #cbd5e1;border-radius:6px;overflow:hidden;background:#ffffff}.cb-split-side{display:flex;align-items:center;justify-content:center;width:28px;height:24px;cursor:pointer;font-family:sans-serif;font-size:11px;font-weight:600;color:#64748b;transition:background .18s ease,color .18s ease}.cb-split-side input{display:none}.cb-split-side:first-child{border-right:1px solid #e2e8f0}.cb-split-side input:checked + span{color:#2f6fe4;background:#eff6ff;width:100%;height:100%;display:flex;align-items:center;justify-content:center}",
    "js": ""
  },

  {
    "id": "cb-steel-flat",
